<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Study Planner</title>

  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="dashboard-page">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <span>📚</span>
      <span>StudyPlanner</span>
    </div>

    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-item active">🏠 Dashboard</a>
      <a href="#" class="nav-item" onclick="showAddTaskModal()">➕ Add Task</a>
    </nav>

    <div class="sidebar-user">
      <div class="user-avatar">
        <%= (user?.name || 'U').charAt(0).toUpperCase() %>
      </div>

      <div class="user-info">
        <div class="user-name"><%= user?.name || 'User' %></div>
        <div class="user-email"><%= user?.email || '' %></div>
      </div>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="dashboard-main">

    <header class="dashboard-header">
      <h1>My Study Planner</h1>
    </header>

    <!-- STATS (SAFE FIX HERE 👇) -->
    <div class="stats-grid">

      <div class="stat-card">
        <div class="stat-number"><%= stats?.total || 0 %></div>
        <div class="stat-label">Total Tasks</div>
      </div>

      <div class="stat-card">
        <div class="stat-number"><%= stats?.pending || 0 %></div>
        <div class="stat-label">Pending</div>
      </div>

      <div class="stat-card">
        <div class="stat-number"><%= stats?.completed || 0 %></div>
        <div class="stat-label">Completed</div>
      </div>

      <div class="stat-card">
        <div class="stat-number"><%= stats?.overdue || 0 %></div>
        <div class="stat-label">Overdue</div>
      </div>

    </div>

    <!-- FILTERS -->
    <div class="filters-bar">
      <select id="filterSubject" onchange="applyFilters()">
        <option value="">All Subjects</option>
        <% (subjects || []).forEach(subject => { %>
          <option value="<%= subject %>"><%= subject %></option>
        <% }) %>
      </select>
    </div>

    <!-- TASKS -->
    <div class="tasks-container">

      <div id="tasksList">
        <% if (!tasks || tasks.length === 0) { %>
          <p>No tasks yet</p>
        <% } %>
      </div>

    </div>

  </main>

  <script>
    let allTasks = <%- JSON.stringify(tasks || []) %>;
  </script>

  <script src="/js/dashboard.js"></script>

</body>
</html>
